# Brew & Scoop — environment variables
# Copy to .env and export before running the app or cron script.

# Flask
BREW_SCOOP_SECRET_KEY=change-me-in-production
BREW_SCOOP_ADMIN_USERNAME=admin
BREW_SCOOP_ADMIN_PASSWORD=admin@123
BREW_SCOOP_ADMIN_NAME=Administrator

# Database — use a different file per environment (never commit *.db)
# Local/testing:
# BREW_SCOOP_DATABASE=./brew_scoop_dev.db
# Production server:
# BREW_SCOOP_DATABASE=/var/lib/brew-scoop/brew_scoop.db

# ── Email (pick ONE provider for production) ────────────────────────────────
# PythonAnywhere web apps often block Gmail SMTP — use brevo, resend, mailgun,
# or sendgrid (all use HTTPS).

# EMAIL_PROVIDER=brevo
# EMAIL_FROM_NAME=Brew & Scoop
# SMTP_FROM=your-verified-sender@example.com

# --- Brevo (recommended — free tier, easy sender verification) ---
# EMAIL_PROVIDER=brevo
# BREVO_API_KEY=xkeysib-your-api-key
# SMTP_FROM=brewscoop1@gmail.com

# --- Resend (simple, good for developers) ---
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=re_your-api-key
# SMTP_FROM=onboarding@resend.dev

# --- Mailgun ---
# EMAIL_PROVIDER=mailgun
# MAILGUN_API_KEY=your-api-key
# MAILGUN_DOMAIN=mg.yourdomain.com
# MAILGUN_REGION=us
# SMTP_FROM=postmaster@mg.yourdomain.com

# --- SendGrid ---
# EMAIL_PROVIDER=sendgrid
# SENDGRID_API_KEY=SG.your-api-key
# SMTP_FROM=your-verified-sender@example.com

# --- SMTP (local dev only in most cases) ---
# EMAIL_PROVIDER=smtp
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=your-email@gmail.com
# SMTP_USE_TLS=true

# Base URL for password reset links (required in production)
# APP_BASE_URL=https://brewscoop.pythonanywhere.com
# PASSWORD_RESET_EXPIRY_HOURS=48

# PythonAnywhere: .env is not in git — create it on the server or use
# Web → Environment variables, then Reload the web app.
# Test: python3.10 scripts/test_smtp.py --send you@example.com

# Optional extra admin report recipients (comma-separated)
# BREW_SCOOP_EXTRA_REPORT_EMAILS=owner@example.com,manager@example.com
