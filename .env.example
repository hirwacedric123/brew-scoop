# Brew & Scoop — environment variables
# Copy to .env and export before running the app or cron script.

# Flask
BREW_SCOOP_SECRET_KEY=change-me-in-production
BREW_SCOOP_ADMIN_USERNAME=admin
BREW_SCOOP_ADMIN_PASSWORD=admin@123
BREW_SCOOP_ADMIN_NAME=Administrator

# Database — use a different file per environment (never commit *.db)
# Local/testing:
# BREW_SCOOP_DATABASE=./brew_scoop_dev.db
# Production server:
# BREW_SCOOP_DATABASE=/var/lib/brew-scoop/brew_scoop.db

# SMTP — required for daily report emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your-email@gmail.com
SMTP_USE_TLS=true

# Optional extra admin report recipients (comma-separated)
# BREW_SCOOP_EXTRA_REPORT_EMAILS=owner@example.com,manager@example.com
