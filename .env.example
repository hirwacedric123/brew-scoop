# Brew & Scoop — environment variables
# Copy to .env and export before running the app or cron script.

# Flask
BREW_SCOOP_SECRET_KEY=change-me-in-production
BREW_SCOOP_ADMIN_USERNAME=admin
BREW_SCOOP_ADMIN_PASSWORD=admin@123
BREW_SCOOP_ADMIN_NAME=Administrator

# Database — use a different file per environment (never commit *.db)
# Local/testing:
# BREW_SCOOP_DATABASE=./brew_scoop_dev.db
# Production server:
# BREW_SCOOP_DATABASE=/var/lib/brew-scoop/brew_scoop.db

# SMTP — required for daily report and password reset emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your-email@gmail.com
SMTP_USE_TLS=true
# Use for port 465 instead: SMTP_PORT=465, SMTP_USE_SSL=true, SMTP_USE_TLS=false

# Base URL for links in password reset emails (required in production)
# APP_BASE_URL=https://your-server.pythonanywhere.com
# PASSWORD_RESET_EXPIRY_HOURS=48

# PythonAnywhere: .env is not deployed via git — create it on the server or set
# Web → Environment variables. Gmail SMTP may fail with "Network is unreachable";
# run: python scripts/test_smtp.py --send you@example.com

# Optional extra admin report recipients (comma-separated)
# BREW_SCOOP_EXTRA_REPORT_EMAILS=owner@example.com,manager@example.com
